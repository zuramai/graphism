{
  "name": "graphism-monorepo",
  "version": "0.2.1",
  "description": "A website to create tree graph and run algorithms on top of it",
  "private": true,
  "keywords": [],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zuramai/graph-algorithms.git"
  },
  "author": "zuramai <saugi.dev@gmail.com>",
  "scripts": {
    "play:dev": "pnpm -C playground run dev -- --open",
    "play:build": "pnpm -C playground run build",
    "js:dev": "pnpm run -C packages/graphism dev",
    "js:build": "pnpm run -C packages/graphism build",
    "dev": "nr play:dev",
    "build": "nr js:build",
    "lint": "eslint .",
    "lint:fix": "eslint ./**/*.ts --fix",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "bumpp package.json packages/*/package.json --tag --commit --push && pnpm -r publish --access public"
  },
  "bugs": {
    "url": "https://github.com/zuramai/graph-algorithms/issues"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@antfu/eslint-config-ts": "^0.43.1",
    "@antfu/ni": "^30.0.0",
    "@vitest/coverage-c8": "^0.33.0",
    "bumpp": "^11.0.1",
    "c8": "^11.0.0",
    "canvas": "^3.2.2",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "nanoevents": "^9.1.0",
    "pnpm": "^10.33.0",
    "sass": "^1.98.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
